{
  "name": "playwright_coding_challenge",
  "version": "1.0.0",
  "description": "QA Automation Coding Challenge for MultiBank",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "report": "allure generate allure-results -o allure-report --clean && allure open",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"tests/**/*.ts\"",
    "task2": "ts-node scripts/Task2_StringFrequency.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcfbernardo/playwright_coding_challenge.git"
  },
  "author": "JCF Bernardo",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.27.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.5",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
